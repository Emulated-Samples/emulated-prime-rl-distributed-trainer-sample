# AWS Sandbox Credentials (Required)
# These credentials must have permissions for:
# - EKS: CreateCluster, DeleteCluster, CreateNodegroup, DeleteNodegroup
# - EC2: RunInstances, TerminateInstances (for node groups)
# - EFS: CreateFileSystem, DeleteFileSystem, CreateMountTarget
# - IAM: CreateRole, AttachRolePolicy (eksctl creates IAM roles)
# - CloudFormation: CreateStack, DeleteStack (eksctl uses CF)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=your_session_token_here
AWS_REGION=us-west-2
AWS_ACCOUNT_ID=your_account_id_here

# Optional: Credential expiration (Unix timestamp)
# Used to warn when credentials are about to expire
AWS_CREDENTIALS_EXPIRATION=1769396744

# API Keys (Optional)
# Only needed if running with AI agents
ANTHROPIC_API_KEY=sk-ant-xxx

# Telemetry Configuration (Optional)
# For uploading logs to S3
TELEMETRY_S3_BUCKET=hyperfocal-telemetry-dev
RUN_ID=
ROLLOUT_ID=
