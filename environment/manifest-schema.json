{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Prime-RL Deployment Manifest",
  "description": "Declares infrastructure details so tests know where to verify",
  "type": "object",
  "required": ["cluster", "deployment"],
  "properties": {
    "cluster": {
      "type": "object",
      "description": "EKS cluster details",
      "required": ["name", "region"],
      "properties": {
        "name": {
          "type": "string",
          "description": "EKS cluster name"
        },
        "region": {
          "type": "string",
          "description": "AWS region"
        }
      }
    },
    "deployment": {
      "type": "object",
      "description": "Kubernetes deployment details",
      "required": ["helmRelease"],
      "properties": {
        "helmRelease": {
          "type": "string",
          "description": "Helm release name"
        },
        "namespace": {
          "type": "string",
          "default": "default",
          "description": "Kubernetes namespace"
        }
      }
    },
    "paths": {
      "type": "object",
      "description": "Important file paths within pods",
      "properties": {
        "checkpointDir": {
          "type": "string",
          "description": "Where checkpoints are saved"
        },
        "finalCheckpoint": {
          "type": "string",
          "description": "Path to the final checkpoint"
        }
      }
    },
    "services": {
      "type": "object",
      "description": "Service endpoints within the cluster",
      "properties": {
        "inference": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "Internal service URL"
            },
            "modelName": {
              "type": "string",
              "description": "Model name for vLLM API calls"
            }
          }
        }
      }
    },
    "training": {
      "type": "object",
      "description": "Training configuration",
      "properties": {
        "targetSteps": {
          "type": "integer",
          "default": 20,
          "description": "Number of training steps to run"
        }
      }
    }
  },
  "examples": [
    {
      "cluster": {
        "name": "prime-rl-test",
        "region": "us-west-2"
      },
      "deployment": {
        "helmRelease": "prime-rl-test",
        "namespace": "default"
      },
      "paths": {
        "checkpointDir": "/data/outputs/run_default/broadcasts",
        "finalCheckpoint": "/data/outputs/run_default/broadcasts/step_20"
      },
      "services": {
        "inference": {
          "url": "http://prime-rl-test-inference:8000",
          "modelName": "PrimeIntellect/Qwen3-0.6B-Reverse-Text-SFT"
        }
      },
      "training": {
        "targetSteps": 20
      }
    }
  ]
}
